# Reduce CDN stickiness after content ships (AI tools + phone caches)
# Render Static Site headers — https://render.com/docs/static-site-headers

/
  Cache-Control: public, max-age=0, must-revalidate, s-maxage=60

/*.html
  Cache-Control: public, max-age=0, must-revalidate, s-maxage=60

/index.html
  Cache-Control: public, max-age=0, must-revalidate, s-maxage=60

/*.md
  Cache-Control: public, max-age=0, must-revalidate, s-maxage=0

/LIVE-HOMEPAGE-COPY.md
  Cache-Control: no-store

/style.css
  Cache-Control: public, max-age=31536000, immutable

/script.js
  Cache-Control: public, max-age=31536000, immutable

/chat.js
  Cache-Control: public, max-age=31536000, immutable

/assets/*
  Cache-Control: public, max-age=31536000, immutable
